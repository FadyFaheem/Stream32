{
  "name": "stream32-desktop",
  "version": "0.1.0",
  "description": "Desktop companion for the Stream32 open-source stream deck",
  "main": "src/main.js",
  "author": {
    "name": "Fady Faheem",
    "email": "contact@fadyfaheem.com"
  },
  "homepage": "https://github.com/FadyFaheem/Stream32",
  "repository": {
    "type": "git",
    "url": "https://github.com/FadyFaheem/Stream32.git"
  },
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "electron .",
    "check": "node --check src/main.js && node --check src/preload.js && node --check src/tray.js && node --check src/updater.js && node --check src/autostart.js && node --check src/renderer/renderer.js",
    "test": "node --test",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.stream32.desktop",
    "productName": "Stream32",
    "copyright": "Copyright © 2026 Fady Faheem",
    "asar": true,
    "files": [
      "src/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../assets/logo.png",
        "to": "logo.png"
      }
    ],
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "FadyFaheem",
        "repo": "Stream32"
      }
    ],
    "win": {
      "icon": "../assets/logo.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "artifactName": "${productName}-${version}-${arch}-Setup.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Stream32",
      "deleteAppDataOnUninstall": false
    },
    "portable": {
      "artifactName": "${productName}-${version}-${arch}-Portable.${ext}"
    },
    "mac": {
      "icon": "../assets/logo.png",
      "category": "public.app-category.utilities",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "../assets/logo.png",
      "category": "Utility",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
