{
  "stream32Plugin": 1,
  "id": "obs-studio",
  "name": "OBS Studio Hotkeys",
  "version": "1.0.0",
  "description": "Configurable hotkeys for common OBS Studio controls.",
  "actions": [
    {
      "id": "toggle-streaming",
      "name": "Start / stop streaming hotkey",
      "description": "Send a configurable chord. Assign the same chord to Start Streaming and Stop Streaming in OBS Settings > Hotkeys.",
      "category": "Streaming",
      "icon": "live_tv",
      "keywords": ["obs", "stream", "streaming", "live"],
      "fields": [
        {
          "id": "key",
          "type": "select",
          "label": "Key",
          "options": [
            { "value": "F1", "label": "F1" },
            { "value": "F2", "label": "F2" },
            { "value": "F3", "label": "F3" },
            { "value": "F4", "label": "F4" },
            { "value": "F5", "label": "F5" },
            { "value": "F6", "label": "F6" },
            { "value": "F7", "label": "F7" },
            { "value": "F8", "label": "F8" },
            { "value": "F9", "label": "F9" },
            { "value": "F10", "label": "F10" },
            { "value": "F11", "label": "F11" },
            { "value": "F12", "label": "F12" }
          ],
          "default": "F8"
        },
        { "id": "ctrl", "type": "toggle", "label": "Control" },
        { "id": "shift", "type": "toggle", "label": "Shift" },
        { "id": "alt", "type": "toggle", "label": "Alt / Option" },
        { "id": "meta", "type": "toggle", "label": "Windows / Command" }
      ],
      "platforms": {
        "win32": {
          "type": "hotkey",
          "key": { "setting": "key" },
          "ctrl": { "setting": "ctrl" },
          "shift": { "setting": "shift" },
          "alt": { "setting": "alt" },
          "meta": { "setting": "meta" }
        },
        "darwin": {
          "type": "hotkey",
